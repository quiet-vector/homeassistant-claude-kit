# Home Assistant Configuration Management - .gitignore

# Secrets and sensitive data
config/secrets.yaml
config/.storage/
config/home-assistant.log*
config/OZW_Log.txt
config/ip_bans.yaml
config/.uuid
config/.HA_VERSION

# Python
venv/
venv
__pycache__/
*.py[cod]
*.pyc
*.pyo
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.history/
.playwright-mcp/
.superpowers/

# OS
.DS_Store
Thumbs.db

# Backups
backups/
*.backup
*.bak
*.tar.gz

# Temporary files
*.tmp
*.temp
.cache/
temp/

# Logs
*.log

# Environment variables
.env
.env.local
dashboard/.env.local
dashboard/dist/

# Node modules (if using any JS tools)
node_modules/

# SSH keys (if accidentally placed here)
*.pem
*.key
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*
id_xmss*
*.ppk
config/*.key
config/*.token
config/*.pid
config/*.uuid

# Environment files (all variants)
.env.*
!.env.example
*.token

# Database files
*.db
*.db-shm
*.db-wal

# Home Assistant specific temporary files
config/deps/
config/tts/
config/.shopping_list.json
config/.google.token
config/nest/
config/.cloud/

# Custom components (managed by HACS)
config/custom_components/

# Personal configuration that shouldn't be shared
config/known_devices.yaml
config/automations_backup/
config/scripts_backup/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Documentation builds
docs/_build/

# PyCharm
.idea/

# Jupyter Notebook
.ipynb_checkpoints

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Development tools
.pre-commit-cache/
.flake8
.pylint.d/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Development artifacts
.python_check.log
*.log

# Virtual Environment symlink (points to ../venv)
# Note: Both venv/ and venv symlink are ignored above
config/claude-code-ha/

# Runtime files pulled from HA (not config)
config/.ha_run.lock
config/go2rtc-*
config/.storage/

# Zigbee2MQTT runtime/database files
config/zigbee2mqtt/database.db*
config/zigbee2mqtt/state.json*
config/zigbee2mqtt/log

# ESPHome secrets
config/esphome/secrets.yaml

# Working files / scratch
nr_flow_edited.json

# Node-RED runtime files (keep only flows.json)
config/node-red/.sessions/
config/node-red/flows_cred.json

# Public kit specific
config/go2rtc.yaml
.claude/projects/
.claude/privacy-patterns
memory/
setup-state.json
