{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(make *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(python tools/*)",
      "Bash(source venv/bin/activate*)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(stat *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(cat *secrets*)",
      "Bash(cat *.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/yaml-formatter.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/posttooluse-ha-validation.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/posttooluse-python-quality.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/posttooluse-dashboard-typecheck.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pretooluse-ha-push-validation.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/privacy-guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
